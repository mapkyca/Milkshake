{
  "name": "task-manager",
  "version": "0.1.0",
  "description": "Local-first task manager – personal RTM replacement",
  "private": true,
  "scripts": {
    "dev:api": "nodemon --exec \"tsx src/api/server.ts\" --ext ts,js --ignore dist/ --ignore src/web/",
    "dev:web": "vite",
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc --project tsconfig.build.json",
    "build:web": "vite build",
    "start": "node dist/api/server.js",
    "task": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express": "^4.21.0",
    "knex": "^3.1.0",
    "rrule": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.51.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.5",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2.0.5"
  }
}
